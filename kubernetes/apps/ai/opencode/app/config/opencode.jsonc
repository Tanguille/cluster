{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/minimax-m2.5-free",
  "plugin": [
    "cc-safety-net",
    "@tarquinen/opencode-dcp@latest",
    "oh-my-opencode-slim"
  ],
  "mcp": {
    "toolhive": {
      "type": "remote",
      "url": "http://vmcp-unified.ai.svc.cluster.local:4483/mcp",
      "enabled": true
    },
    "flux": {
      "type": "remote",
      "url": "http://vmcp-flux.ai.svc.cluster.local:4483/mcp",
      "enabled": true
    },
    "observability": {
      "type": "remote",
      "url": "http://vmcp-observability.ai.svc.cluster.local:4483/mcp",
      "enabled": true
    },
    "homeassistant": {
      "type": "remote",
      "url": "http://vmcp-ha.ai.svc.cluster.local:4483/mcp",
      "enabled": true
    },
    "search": {
      "type": "remote",
      "url": "http://vmcp-search.ai.svc.cluster.local:4483/mcp",
      "enabled": true
    },
    "resources": {
      "type": "remote",
      "url": "http://vmcp-resources.ai.svc.cluster.local:4483/mcp",
      "enabled": true
    }
  },
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM",
      "options": {
        "baseURL": "http://litellm.ai.svc.cluster.local/v1",
        "apiKey": "{env:LITELLM_API_KEY}"
      }
    }
  }
}
