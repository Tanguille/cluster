{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "11.5.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "2.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    }
  ],
  "tags": ["ai", "inference", "vllm"],
  "description": "vLLM inference server metrics: request queue, token throughput, latency percentiles, KV cache pressure, and prefix cache efficiency.",
  "uid": "vllm-inference",
  "title": "vLLM Inference",
  "schemaVersion": 41,
  "graphTooltip": 1,
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "timezone": "browser",
  "refresh": "30s",
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "panels": [],
      "title": "Overview",
      "type": "row"
    },
    {
      "id": 2,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "type": "stat",
      "title": "Running Requests",
      "description": "Requests currently being processed by the vLLM engine scheduler.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "unit": "none",
          "mappings": [],
          "min": 0,
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "vllm:num_requests_running",
          "legendFormat": "running",
          "editorMode": "code",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "type": "stat",
      "title": "Waiting Requests",
      "description": "Requests queued by the scheduler waiting to be processed.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "none",
          "mappings": [],
          "min": 0,
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "vllm:num_requests_waiting",
          "legendFormat": "waiting",
          "editorMode": "code",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "type": "stat",
      "title": "KV Cache Usage",
      "description": "Percentage of GPU KV cache blocks currently allocated. High values increase preemption risk under load spikes.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          },
          "unit": "percent",
          "mappings": [],
          "min": 0,
          "max": 100,
          "noValue": "—"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "vllm:kv_cache_usage_perc * 100",
          "legendFormat": "KV cache %",
          "editorMode": "code",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "type": "stat",
      "title": "Total Generated Tokens",
      "description": "Cumulative count of generation tokens output by the model since last reset.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "unit": "short",
          "mappings": [],
          "min": 0,
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "vllm:generation_tokens_total",
          "legendFormat": "total",
          "editorMode": "code",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 6,
      "panels": [],
      "title": "Request Flow",
      "type": "row"
    },
    {
      "id": 7,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "type": "timeseries",
      "title": "Requests Running / Waiting",
      "description": "Stacked view of scheduler queue depth. A widening gap indicates scheduling pressure or insufficient batch capacity.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "none",
          "custom": {
            "stacking": { "mode": "normal", "group": "A" },
            "fillOpacity": 50,
            "lineWidth": 1,
            "pointSize": 3,
            "showPoints": "never"
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max", "last"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "vllm:num_requests_running",
          "legendFormat": "running",
          "editorMode": "code",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "vllm:num_requests_waiting",
          "legendFormat": "waiting",
          "editorMode": "code",
          "range": true,
          "refId": "B"
        }
      ]
    },
    {
      "id": 8,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "type": "timeseries",
      "title": "Finished Requests by Reason",
      "description": "Rate of finished requests broken down by finish reason (stop, length, error, abort). Spikes in error/abort indicate problems.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "req/s",
          "custom": {
            "stacking": { "mode": "normal", "group": "A" },
            "fillOpacity": 50,
            "lineWidth": 1,
            "pointSize": 3,
            "showPoints": "never"
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "error" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "red" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "abort" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "orange" }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max", "last"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (finished_reason) (rate(vllm:request_success_total[$__rate_interval]))",
          "legendFormat": "{{finished_reason}}",
          "editorMode": "code",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 9,
      "panels": [],
      "title": "Token Throughput",
      "type": "row"
    },
    {
      "id": 10,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "type": "timeseries",
      "title": "Token Throughput",
      "description": "Prompt processing and generation token rates. The ratio between the two reflects workload mix (prefill-heavy vs decode-heavy).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "tok/s",
          "custom": {
            "stacking": { "mode": "none", "group": "A" },
            "fillOpacity": 30,
            "lineWidth": 1,
            "pointSize": 3,
            "showPoints": "never"
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max", "last"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(vllm:prompt_tokens_total[$__rate_interval])",
          "legendFormat": "prompt tok/s",
          "editorMode": "code",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(vllm:generation_tokens_total[$__rate_interval])",
          "legendFormat": "generation tok/s",
          "editorMode": "code",
          "range": true,
          "refId": "B"
        }
      ]
    },
    {
      "id": 11,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "type": "timeseries",
      "title": "Tokens per Engine Step",
      "description": "Average number of tokens generated per single engine iteration step. Reflects batching efficiency — higher values mean the engine is processing more tokens in parallel.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "tokens",
          "custom": {
            "stacking": { "mode": "none", "group": "A" },
            "fillOpacity": 30,
            "lineWidth": 1,
            "pointSize": 3,
            "showPoints": "never"
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max", "last"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(vllm:iteration_tokens_total_sum[$__rate_interval]) / rate(vllm:iteration_tokens_total_count[$__rate_interval])",
          "legendFormat": "avg tokens/step",
          "editorMode": "code",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 12,
      "panels": [],
      "title": "Latency",
      "type": "row"
    },
    {
      "id": 13,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "type": "timeseries",
      "title": "Time to First Token (TTFT)",
      "description": "Time to first token latency at p50, p95, p99. High values indicate prompt processing bottlenecks — long prompts or scheduler contention.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s",
          "custom": {
            "stacking": { "mode": "none", "group": "A" },
            "fillOpacity": 20,
            "lineWidth": 1,
            "pointSize": 3,
            "showPoints": "never"
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p99" },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": { "fill": "dash", "dash": [10, 5] }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max", "last"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, sum(rate(vllm:time_to_first_token_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p50",
          "editorMode": "code",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum(rate(vllm:time_to_first_token_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p95",
          "editorMode": "code",
          "range": true,
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum(rate(vllm:time_to_first_token_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p99",
          "editorMode": "code",
          "range": true,
          "refId": "C"
        }
      ]
    },
    {
      "id": 14,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "type": "timeseries",
      "title": "Inter-Token Latency (ITL)",
      "description": "Time between successive tokens in the decode phase at p50, p95, p99. Lower is better — high ITL indicates per-step compute bottleneck or memory bandwidth saturation.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s",
          "custom": {
            "stacking": { "mode": "none", "group": "A" },
            "fillOpacity": 20,
            "lineWidth": 1,
            "pointSize": 3,
            "showPoints": "never"
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p99" },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": { "fill": "dash", "dash": [10, 5] }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max", "last"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, sum(rate(vllm:inter_token_latency_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p50",
          "editorMode": "code",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum(rate(vllm:inter_token_latency_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p95",
          "editorMode": "code",
          "range": true,
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum(rate(vllm:inter_token_latency_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p99",
          "editorMode": "code",
          "range": true,
          "refId": "C"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 15,
      "panels": [],
      "title": "System Health",
      "type": "row"
    },
    {
      "id": 16,
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 33 },
      "type": "timeseries",
      "title": "KV Cache Usage",
      "description": "KV cache utilization over time. Sustained values above 80% mean the engine is operating near its peak capacity. Above 95% increases preemption risk.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "custom": {
            "stacking": { "mode": "none", "group": "A" },
            "fillOpacity": 60,
            "lineWidth": 1,
            "pointSize": 3,
            "showPoints": "never"
          },
          "mappings": [],
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max", "last"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "vllm:kv_cache_usage_perc * 100",
          "legendFormat": "KV cache %",
          "editorMode": "code",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 17,
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 33 },
      "type": "timeseries",
      "title": "Preemption Rate",
      "description": "Rate of request preemptions per second. Non-zero values indicate the KV cache is full and the engine is evicting active requests under load.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "none",
          "custom": {
            "stacking": { "mode": "none", "group": "A" },
            "fillOpacity": 60,
            "lineWidth": 1,
            "pointSize": 3,
            "showPoints": "never"
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max", "last"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(vllm:num_preemptions_total[$__rate_interval])",
          "legendFormat": "preemptions/s",
          "editorMode": "code",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 18,
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 33 },
      "type": "timeseries",
      "title": "Prefix Cache Hit Ratio",
      "description": "Percentage of prefix cache queries that resulted in a hit. High ratio improves TTFT for repeated prompt prefixes. Low ratio may indicate poor cache locality or cache evictions.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "custom": {
            "stacking": { "mode": "none", "group": "A" },
            "fillOpacity": 60,
            "lineWidth": 1,
            "pointSize": 3,
            "showPoints": "never"
          },
          "mappings": [],
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max", "last"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
