{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "11.5.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "2.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    }
  ],
  "tags": ["ai", "inference", "vllm"],
  "description": "vLLM inference server metrics: request throughput, token throughput, latency, and GPU KV cache utilization.",
  "uid": "vllm-inference",
  "title": "vLLM Inference",
  "schemaVersion": 41,
  "graphTooltip": 1,
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "timezone": "browser",
  "refresh": "30s",
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "panels": [],
      "title": "Overview",
      "type": "row"
    },
    {
      "id": 2,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "type": "stat",
      "title": "Running Requests",
      "description": "Current number of requests being processed by the vLLM engine.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "none",
          "mappings": [],
          "min": 0,
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "vllm:num_requests_running",
          "legendFormat": "running",
          "editorMode": "code",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "type": "stat",
      "title": "Waiting Requests",
      "description": "Current number of requests waiting in the batching queue for processing.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "none",
          "mappings": [],
          "min": 0,
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "vllm:num_requests_waiting",
          "legendFormat": "waiting",
          "editorMode": "code",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "type": "stat",
      "title": "GPU KV Cache Usage",
      "description": "Percentage of GPU KV cache blocks currently used. High usage (>95%) may cause preemptions under load spikes.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          },
          "unit": "percent",
          "mappings": [],
          "min": 0,
          "max": 100,
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "vllm:gpu_cache_usage_perc",
          "legendFormat": "cache usage",
          "editorMode": "code",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "type": "stat",
      "title": "Generation Throughput",
      "description": "Average generation throughput over the last 5 minutes.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "tok/s",
          "mappings": [],
          "min": 0,
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "vllm:avg_generation_throughput_toks_per_sec",
          "legendFormat": "gen tok/s",
          "editorMode": "code",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 6,
      "panels": [],
      "title": "Request Flow & Throughput",
      "type": "row"
    },
    {
      "id": 7,
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 6 },
      "type": "timeseries",
      "title": "Requests Running / Waiting",
      "description": "Stacked view of requests currently running and waiting in the vLLM engine. A widening gap indicates scheduling pressure.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "none",
          "custom": {
            "stacking": { "mode": "normal", "group": "A" },
            "fillOpacity": 50,
            "lineWidth": 1,
            "pointSize": 3,
            "showPoints": "never"
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max", "last"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "vllm:num_requests_running",
          "legendFormat": "running",
          "editorMode": "code",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "vllm:num_requests_waiting",
          "legendFormat": "waiting",
          "editorMode": "code",
          "range": true,
          "refId": "B"
        }
      ]
    },
    {
      "id": 8,
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "type": "timeseries",
      "title": "Finished Requests",
      "description": "Rate of finished requests processed by the vLLM engine (all statuses).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "req/s",
          "custom": {
            "stacking": { "mode": "normal", "group": "A" },
            "fillOpacity": 50,
            "lineWidth": 1,
            "pointSize": 3,
            "showPoints": "never"
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max", "last"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(vllm:finished_requests_total[$__rate_interval]))",
          "legendFormat": "total",
          "editorMode": "code",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "type": "timeseries",
      "title": "Token Throughput",
      "description": "Prompt processing throughput vs generation throughput, measured in tokens per second.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "tok/s",
          "custom": {
            "stacking": { "mode": "none", "group": "A" },
            "fillOpacity": 30,
            "lineWidth": 1,
            "pointSize": 3,
            "showPoints": "never"
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max", "last"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(vllm:prompt_tokens_total[$__rate_interval])",
          "legendFormat": "prompt tok/s",
          "editorMode": "code",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(vllm:generation_tokens_total[$__rate_interval])",
          "legendFormat": "generation tok/s",
          "editorMode": "code",
          "range": true,
          "refId": "B"
        }
      ]
    },
    {
      "id": 10,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "type": "timeseries",
      "title": "Time to First Token (TTFT)",
      "description": "Time to first token latency at p50, p95, and p99 percentiles. High values indicate prompt processing bottlenecks.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s",
          "custom": {
            "stacking": { "mode": "none", "group": "A" },
            "fillOpacity": 20,
            "lineWidth": 1,
            "pointSize": 3,
            "showPoints": "never"
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p99" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 5] } }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max", "last"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, sum(rate(vllm:time_to_first_token_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p50",
          "editorMode": "code",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum(rate(vllm:time_to_first_token_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p95",
          "editorMode": "code",
          "range": true,
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum(rate(vllm:time_to_first_token_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p99",
          "editorMode": "code",
          "range": true,
          "refId": "C"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 11,
      "panels": [],
      "title": "System Health",
      "type": "row"
    },
    {
      "id": 12,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "type": "timeseries",
      "title": "GPU KV Cache Usage",
      "description": "KV cache utilization over time. Sustained values above 95% increase the risk of preemptions under load spikes.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "custom": {
            "stacking": { "mode": "none", "group": "A" },
            "fillOpacity": 50,
            "lineWidth": 1,
            "pointSize": 3,
            "showPoints": "never"
          },
          "mappings": [],
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max", "last"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "vllm:gpu_cache_usage_perc",
          "legendFormat": "KV cache %",
          "editorMode": "code",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 23 },
      "type": "timeseries",
      "title": "Preemption Rate",
      "description": "Rate of request preemptions per second. Sustained non-zero values indicate insufficient KV cache headroom under the current workload.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "none",
          "custom": {
            "stacking": { "mode": "none", "group": "A" },
            "fillOpacity": 50,
            "lineWidth": 1,
            "pointSize": 3,
            "showPoints": "never"
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max", "last"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(vllm:num_preemptions_total[$__rate_interval])",
          "legendFormat": "preemptions/s",
          "editorMode": "code",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 14,
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 23 },
      "type": "timeseries",
      "title": "Prompt Throughput (avg)",
      "description": "Average prompt processing throughput reported by the vLLM engine scheduler.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "tok/s",
          "custom": {
            "stacking": { "mode": "none", "group": "A" },
            "fillOpacity": 50,
            "lineWidth": 1,
            "pointSize": 3,
            "showPoints": "never"
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max", "last"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "vllm:avg_prompt_throughput_toks_per_sec",
          "legendFormat": "prompt tok/s",
          "editorMode": "code",
          "range": true,
          "refId": "A"
        }
      ]
    }
  ],
  "links": [
    {
      "title": "AMD GPU",
      "type": "dashboards",
      "tags": ["amdgpu"]
    }
  ]
}
