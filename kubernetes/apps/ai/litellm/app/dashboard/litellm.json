      },
      "description": "The state of the deployment: 0 = healthy, 1 = partial outage, 2 = complete outage",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "A"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "0": {
                        "color": "green",
                        "index": 0,
                        "text": "healthy"
                      },
                      "1": {
                        "color": "yellow",
                        "index": 1,
                        "text": "partial outage"
                      },
                      "2": {
                        "color": "red",
                        "index": 2,
                        "text": "complete outage"
                      }
                    },
                    "type": "value"
                  }
                ]
