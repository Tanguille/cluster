{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "builtIn": 0,
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "enable": true,
        "expr": "changes(kube_deployment_status_observed_generation{namespace=\"ai\", deployment=\"llama-server\"}[5m]) > 0",
        "hide": false,
        "iconColor": "rgba(0, 120, 215, 1)",
        "name": "Deployments",
        "step": "60s",
        "tagKeys": "deployment",
        "textFormat": "",
        "titleFormat": "Deploy: {{deployment}}",
        "type": "dashboard"
      }
    ]
  },
  "description": "llama.cpp router metrics per selected model. LiteLLM row shows client-visible latency for routes through llama-server.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 100,
      "panels": [],
      "title": "Throughput (last request)",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Last completed request prefill/encode speed (llamacpp:prompt_tokens_seconds). Resets on pod restart.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "short",
          "decimals": 1
        },
        "overrides": []
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 6,
        "h": 6
      },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "wideLayout": true
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "max(max without(endpoint, instance, pod, prometheus) ((label_replace(llamacpp:prompt_tokens_seconds{namespace=\"ai\", service=\"llama-server\"} unless llamacpp:prompt_tokens_seconds{namespace=\"ai\", service=\"llama-server\", model=~\".+\"}, \"model\", \"qwen-3.6\", \"job\", \"(.+)\") or llamacpp:prompt_tokens_seconds{namespace=\"ai\", service=\"llama-server\", model=~\"$model\"})))",
          "legendFormat": "pp",
          "refId": "A",
          "instant": true
        }
      ],
      "title": "Prefill tokens/s",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Last completed request decode speed (llamacpp:predicted_tokens_seconds). Chat/completion presets only; embedding presets have no decode phase.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "short",
          "decimals": 1
        },
        "overrides": []
      },
      "gridPos": {
        "x": 6,
        "y": 1,
        "w": 6,
        "h": 6
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "wideLayout": true
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "max(max without(endpoint, instance, pod, prometheus) ((label_replace(llamacpp:predicted_tokens_seconds{namespace=\"ai\", service=\"llama-server\"} unless llamacpp:predicted_tokens_seconds{namespace=\"ai\", service=\"llama-server\", model=~\".+\"}, \"model\", \"qwen-3.6\", \"job\", \"(.+)\") or llamacpp:predicted_tokens_seconds{namespace=\"ai\", service=\"llama-server\", model=~\"$model\"})))",
          "legendFormat": "tg",
          "refId": "A",
          "instant": true
        }
      ],
      "title": "Decode tokens/s",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "requests_processing and requests_deferred. Deferred > 0 means all parallel slots are busy.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "none",
          "decimals": 0
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": "/deferred/i"
            },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 1
                    },
                    {
                      "color": "red",
                      "value": 5
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 6,
        "h": 6
      },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name",
        "wideLayout": true
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "max without(endpoint, instance, pod, prometheus) ((label_replace(llamacpp:requests_processing{namespace=\"ai\", service=\"llama-server\"} unless llamacpp:requests_processing{namespace=\"ai\", service=\"llama-server\", model=~\".+\"}, \"model\", \"qwen-3.6\", \"job\", \"(.+)\") or llamacpp:requests_processing{namespace=\"ai\", service=\"llama-server\", model=~\"$model\"}))",
          "legendFormat": "processing {{model}}",
          "refId": "A",
          "instant": true
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "max without(endpoint, instance, pod, prometheus) ((label_replace(llamacpp:requests_deferred{namespace=\"ai\", service=\"llama-server\"} unless llamacpp:requests_deferred{namespace=\"ai\", service=\"llama-server\", model=~\".+\"}, \"model\", \"qwen-3.6\", \"job\", \"(.+)\") or llamacpp:requests_deferred{namespace=\"ai\", service=\"llama-server\", model=~\"$model\"}))",
          "legendFormat": "deferred {{model}}",
          "refId": "B",
          "instant": true
        }
      ],
      "title": "Active / deferred",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Largest n_tokens observed (llamacpp:n_tokens_max).",
