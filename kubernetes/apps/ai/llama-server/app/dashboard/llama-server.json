        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "max without(endpoint, instance, pod, prometheus) ((label_replace(llamacpp:n_tokens_max{namespace=\"ai\", service=\"llama-server\"} unless llamacpp:n_tokens_max{namespace=\"ai\", service=\"llama-server\", model=~\".+\"}, \"model\", \"qwen-3.6\", \"job\", \"(.+)\") or llamacpp:n_tokens_max{namespace=\"ai\", service=\"llama-server\", model=~\"$model\"}))",
