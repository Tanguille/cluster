          "expr": "max without(endpoint, instance, pod, prometheus) ((label_replace(llamacpp:prompt_tokens_seconds{namespace=\"ai\", service=\"llama-server\"} unless llamacpp:prompt_tokens_seconds{namespace=\"ai\", service=\"llama-server\", model=~\".+\"}, \"model\", \"qwen-3.6\", \"job\", \"(.+)\") or llamacpp:prompt_tokens_seconds{namespace=\"ai\", service=\"llama-server\", model=~\"$model\"}))",
