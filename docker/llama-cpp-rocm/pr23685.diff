+static __device__ __forceinline__ int32_t pack_q8_1_i8x4(
+        const int8_t q0, const int8_t q1, const int8_t q2, const int8_t q3) {
+    return
+        ((uint32_t) (uint8_t) q0) |
+        ((uint32_t) (uint8_t) q1 <<  8) |
+        ((uint32_t) (uint8_t) q2 << 16) |
+        ((uint32_t) (uint8_t) q3 << 24);
+}
