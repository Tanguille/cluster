{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "abandonments:recommended",
    "github>home-operations/renovate-presets#2.1.0",
    ":timezone(Europe/Brussels)"
  ],
  ignorePaths: ["**/*.sops.*", "**/resources/**"],
  customManagers: [
    {
      description: "Detect ToolHive MCPServer spec.image container references",
      customType: "regex",
      managerFilePatterns: ["/kubernetes/apps/ai/toolhive/config/.+\\.ya?ml$/"],
      matchStrings: [
        "image:\\s+(?<depName>[^:@\\s]+(?:/[^:@\\s]+)*)(?::(?<currentValue>[^@\\s]+))?(?:@(?<currentDigest>sha256:[a-f0-9]+))?"
      ],
      datasourceTemplate: "docker"
    },
    {
      description: "Detect llmkube InferenceService spec.image container references",
      customType: "regex",
      managerFilePatterns: ["/kubernetes/apps/ai/llmkube/models/.+\\.ya?ml$/"],
      matchStrings: [
        "image:\\s+(?<depName>[^:@\\s]+(?:/[^:@\\s]+)*)(?::(?<currentValue>[^@\\s]+))?(?:@(?<currentDigest>sha256:[a-f0-9]+))?"
      ],
      datasourceTemplate: "docker"
    },
    {
      description: "Process Grafana dashboards in GrafanaDashboard CRs",
      customType: "regex",
      managerFilePatterns: ["/grafanadashboard\\.yaml(?:\\.j2)?$/"],
      matchStrings: [
        "grafanaCom:\\s*\\n\\s*id:\\s*(?<depName>\\d+)\\s*\\n\\s*revision:\\s*(?<currentValue>\\d+)"
      ],
      datasourceTemplate: "custom.grafana-dashboards",
      versioningTemplate: "regex:^(?<major>\\d+)$",
      autoReplaceStringTemplate: "grafanaCom:\n    id: {{depName}}\n    revision: {{newValue}}"
    },
    {
      description: "GrafanaDashboard spec.url pinned to GitHub release tags",
      customType: "regex",
      managerFilePatterns: ["/grafanadashboard\\.yaml(?:\\.j2)?$/"],
      matchStringsStrategy: "recursive",
      matchStrings: [
        "url:\\s+https://raw\\.githubusercontent\\.com/(?<depName>[^/\\s]+/[^/\\s]+)/",
        "(?<currentValue>v\\d+\\.\\d+\\.\\d+)"
      ],
      datasourceTemplate: "github-releases",
      autoReplaceStringTemplate: "{{{newValue}}}"
    },
    {
      description: "qBitrr ConfigVersion (semver, no v prefix)",
      customType: "regex",
      managerFilePatterns: ["/qbitrr/config/config\\.toml$/"],
      matchStrings: ['ConfigVersion\\s*=\\s*"(?<currentValue>[^"]+)"'],
      depNameTemplate: "feramance/qbitrr",
      datasourceTemplate: "docker",
      // newValue is already v-stripped by the config.toml extractVersion rule below, so write it
      // verbatim. (A {{replace}} here would re-extract empty and abort the branch with "update failure".)
      autoReplaceStringTemplate: 'ConfigVersion = "{{{newValue}}}"'
    },
    {
      description: "HuggingFace model files revision-pinned in llmkube Model sources (HF model repos are git repos; digest = repo commit sha)",
      customType: "regex",
      managerFilePatterns: ["/kubernetes/apps/ai/llmkube/models/.+\\.ya?ml$/"],
      matchStrings: [
        "source:\\s+https://huggingface\\.co/(?<depName>[^/\\s]+/[^/\\s]+)/resolve/(?<currentDigest>[a-f0-9]{40})/"
      ],
      packageNameTemplate: "https://huggingface.co/{{depName}}",
      currentValueTemplate: "main",
      datasourceTemplate: "git-refs"
    },
  ],
  packageRules: [
    // Auto-merge rules
    {
      description: "Auto-merge trusted OCI digests",
      matchDatasources: ["docker"],
      matchUpdateTypes: ["digest"],
      matchPackageNames: ["/home-operations/"],
      automerge: true,
      automergeType: "pr"
    },
    {
      description: "Auto-merge GitHub Actions",
      matchManagers: ["github-actions"],
      matchUpdateTypes: ["minor", "patch", "digest"],
      automerge: true,
      automergeType: "branch",
      minimumReleaseAge: "3 days"
    },
    // Grouping rules
    {
      description: "sglang-rdna4 build inputs (fork ref + ROCm base digest + miniforge) — one review PR, no automerge; merging fires the GPU-free build workflow and mints a new image digest",
      groupName: "sglang-rdna4",
      matchFileNames: ["docker/sglang-rdna4/Dockerfile"],
      automerge: false
    },
    {
      description: "sglang-rdna4 deployed image digest — review before the HelmRelease rolls the serving pod (Recreate on the single GPU)",
      matchDatasources: ["docker"],
      matchPackageNames: ["ghcr.io/tanguille/sglang-rdna4"],
      automerge: false
    },
    {
      description: "Actions Runner Controller Group",
      groupName: "actions-runner-controller",
      matchDatasources: ["docker"],
      matchPackageNames: [
        "/gha-runner-scale-set-controller/",
        "/gha-runner-scale-set/"
      ],
      group: {
        commitMessageTopic: "{{{groupName}}} group"
      },
      minimumGroupSize: 2
    },
    {
      description: "Flux Operator Group",
      groupName: "flux-operator",
      matchDatasources: ["docker"],
      matchPackageNames: ["/flux-operator/", "/flux-instance/"],
      group: {
        commitMessageTopic: "{{{groupName}}} group"
      },
      minimumGroupSize: 2
    },
    {
      description: "Rook-Ceph Group",
      groupName: "rook-ceph",
      matchDatasources: ["docker"],
      matchPackageNames: ["/rook-ceph/", "/rook-ceph-cluster/"],
      group: {
        commitMessageTopic: "{{{groupName}}} group"
      },
      minimumGroupSize: 2
    },
    {
      description: "ToolHive operator and CRDs group",
      groupName: "toolhive",
      matchDatasources: ["docker"],
      matchPackageNames: ["/stacklok\\/toolhive\\/toolhive-operator/"],
      group: {
        commitMessageTopic: "{{{groupName}}} group"
      },
      minimumGroupSize: 2
    },
    {
      description: "ToolHive MCP server images group",
      groupName: "toolhive-mcp",
      matchDatasources: ["docker"],
      matchFileNames: ["kubernetes/apps/ai/toolhive/config/**"],
      group: {
        commitMessageTopic: "{{{groupName}}} group"
      },
      minimumGroupSize: 2
    },
    {
      description: "Group klipper-exporter image and Grafana dashboard URL",
      groupName: "klipper-exporter",
      matchDatasources: ["docker", "github-releases"],
      matchPackageNames: ["/prometheus-klipper-exporter/"],
      group: {
        commitMessageTopic: "{{{groupName}}}"
      }
    },
    {
      description: "Group spegel chart and Grafana dashboard URL",
      groupName: "spegel",
      matchDatasources: ["docker", "github-releases"],
      matchPackageNames: ["/spegel-org/"],
      group: {
        commitMessageTopic: "{{{groupName}}}"
      }
    },
    {
      description: "nginx sidecar images group",
      groupName: "nginx",
      matchDatasources: ["docker"],
      matchPackageNames: ["nginx"],
      group: {
        commitMessageTopic: "{{{groupName}}}"
      },
      minimumGroupSize: 2
    },
    {
      // No matchManagers on purpose: the HelmRelease image is detected by both helm-values and
      // kubernetes (home-ops points both at every .yaml); constraining managers let one copy
      // escape into a duplicate PR. datasource+file+package already scope this precisely.
      description: "qBitrr: group image tag and ConfigVersion",
      groupName: "qbitrr",
      matchDatasources: ["docker"],
      matchFileNames: ["kubernetes/apps/media/qbittorrent/tools/qbitrr/**"],
      matchPackageNames: ["/feramance\\/qbitrr/"],
      group: {
        commitMessageTopic: "{{{groupName}}}"
      }
    },
    {
      matchManagers: ["custom.regex"],
      matchFileNames: [
        "kubernetes/apps/media/qbittorrent/tools/qbitrr/config/config.toml"
      ],
      matchPackageNames: ["/feramance\\/qbitrr/"],
      extractVersion: "^v(?<version>.*)$"
    },
    // Versioning overrides
    {
      description: "Mixed-segment tags (p2pool v4.15/v4.15.1, hermes v2026.5.29/v2026.5.29.2); docker versioning skips patch bumps",
      matchDatasources: ["docker"],
      matchPackageNames: [
        "ghcr.io/sethforprivacy/p2pool",
        "nousresearch/hermes-agent"
      ],
      versioning: "loose"
    },
    // Labeling rules
    {
      matchUpdateTypes: ["major"],
      addLabels: ["type/major"]
    },
    {
      matchUpdateTypes: ["minor"],
      addLabels: ["type/minor"]
    },
    {
      matchUpdateTypes: ["patch"],
      addLabels: ["type/patch"]
    },
    {
      matchUpdateTypes: ["digest"],
      addLabels: ["type/digest"]
    },
    {
      matchDatasources: ["docker"],
      addLabels: ["renovate/container"]
    },
    {
      matchDatasources: ["helm"],
      addLabels: ["renovate/helm"]
    },
    {
      matchDatasources: ["custom.grafana-dashboards"],
      addLabels: ["renovate/grafana-dashboard"]
    },
    {
      matchManagers: ["github-actions"],
      addLabels: ["renovate/github-action"]
    },
    {
      matchDatasources: ["github-releases"],
      addLabels: ["renovate/github-release"]
    }
  ]
}
